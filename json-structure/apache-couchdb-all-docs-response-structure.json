{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/apache-couchdb/refs/heads/main/json-structure/apache-couchdb-all-docs-response-structure.json",
  "name": "AllDocsResponse",
  "description": "Response from _all_docs or bulk get",
  "type": "object",
  "properties": {
    "total_rows": {
      "type": "int32",
      "description": "Total number of documents in the database",
      "example": 1250
    },
    "offset": {
      "type": "int32",
      "description": "Number of skipped rows",
      "example": 0
    },
    "rows": {
      "type": "array",
      "items": {
        "name": "DocRow",
        "type": "object",
        "description": "A row in an _all_docs response",
        "properties": {
          "id": {
            "type": "string",
            "description": "Document ID",
            "example": "doc001"
          },
          "key": {
            "type": "string",
            "description": "Row key",
            "example": "doc001"
          },
          "value": {
            "type": "object",
            "description": "Row value containing revision info",
            "properties": {
              "rev": {
                "type": "string",
                "example": "1-abc123"
              }
            }
          },
          "doc": {
            "$ref": "#/components/schemas/Document"
          }
        }
      }
    }
  }
}